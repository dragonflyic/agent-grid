# Dockerfile.worker — Ephemeral worker for Fly Machines
FROM python:3.12-slim

WORKDIR /workspace

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl jq \
    && rm -rf /var/lib/apt/lists/*

# Install gh CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js (required for Claude Code CLI)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies (only what the worker needs)
# claude-agent-sdk bundles the Claude Code CLI binary; Node.js is still needed as runtime
RUN pip install --no-cache-dir claude-agent-sdk boto3 httpx awscli

# Create non-root user (Claude Code refuses bypassPermissions as root)
RUN useradd -m -s /bin/bash agent && chown -R agent:agent /workspace

# Pre-create credentials directory for the agent user
RUN mkdir -p /home/agent/.claude && chown -R agent:agent /home/agent/.claude
USER agent

# Copy entrypoint
COPY --chown=agent:agent scripts/worker-entrypoint.sh /worker-entrypoint.sh
RUN chmod +x /worker-entrypoint.sh

ENTRYPOINT ["/worker-entrypoint.sh"]
